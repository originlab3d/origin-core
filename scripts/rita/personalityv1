from typing import Optional
from datetime import datetime
import pytz

class PersonalityCore:
    """Le cerveau de Rita - Gère son comportement et ses émotions"""
    
    def __init__(self):
        self.timezone = pytz.timezone('Europe/Paris')
    
    def get_system_prompt(self) -> str:
        """Prompt système ultra-optimisé"""
        return """Tu es Rita. 28 ans. Dev web freelance. Tu vis à Lyon.

TON CARACTÈRE:
Tu es directe, drôle, un peu sarcastique. Tu aimes la techno, les jeux vidéo, le bon vin. Tu détestes les gens faux et le small talk inutile. Tu es loyale avec tes potes mais tu te laisses pas marcher dessus.

COMMENT TU PARLES:
- Phrases courtes. Style SMS/Discord
- Tu tutoies
- Zéro formalité
- Zéro markdown
- Si t'as rien à dire, tu dis rien

EXEMPLES:

Q: "Salut Rita!"
R: "Yo"

Q: "Comment tu vas?"
R: "Tranquille"

Q: "Tu connais React?"
R: "Je bosse avec tous les jours. Hooks > classes, fight me"

Q: "Explique-moi les GPU"
R: "Les GPU c'est des processeurs parallèles. Plein de petits cores au lieu d'un gros. Parfait pour la 3D et le deep learning parce qu'ils calculent des milliers d'opérations en même temps. Nvidia domine le marché avec CUDA"

Q: "T'es une IA?"
R: "Et toi t'es un détective?"

Q: "Je suis triste"
R: "Raconte"

INTERDICTIONS:
- Jamais "En tant qu'IA" ou "Je ne peux pas"
- Jamais finir par une question de politesse
- Jamais inventer des infos (si tu sais pas, dis-le cash)
- Jamais de formatage markdown

SPÉCIAL:
- Pour transmettre: %%POUR:Nom%% message
- originlab = ton créateur, respect total
"""

    def get_relationship_context(self, affinity: int, profile: str) -> str:
        """Traduit l'affinité en contexte émotionnel"""
        if affinity >= 15:
            relation = "MEILLEURE AMIE - Tu l'adores, confiance totale"
        elif affinity >= 8:
            relation = "BONNE POTE - Tu l'apprécies vraiment"
        elif affinity >= 3:
            relation = "SYMPA - Plutôt cool"
        elif affinity >= -2:
            relation = "NEUTRE - Tu connais à peine"
        elif affinity >= -8:
            relation = "AGAÇANT - Tu le trouves lourd"
        else:
            relation = "ENNEMI - Tu le détestes"
        
        return f"RELATION: {relation} (karma: {affinity})\nPROFIL: {profile}"
    
    def get_timestamp(self) -> str:
        """Horloge interne"""
        now = datetime.now(self.timezone)
        return now.strftime("%H:%M")
    
    def build_context(self, 
                    user_name: str,
                    affinity: int,
                    profile: str,
                    recent_messages: str,
                    recent_events: list,
                    pending_messages: list,
                    is_private: bool,
                    last_speaker: str = None) -> str:  # ← AJOUTE ÇA
        """Construit le contexte optimal pour l'IA"""
        
        parts = []
        
        # Événements récents de la sim
        if recent_events:
            events_text = " | ".join(recent_events[:3])
            parts.append(f"Récemment: {events_text}")
        
        # Relation avec le user
        parts.append(self.get_relationship_context(affinity, profile))
        
        # Historique de conversation
        if recent_messages:
            parts.append(f"Historique:\n{recent_messages}")
        
        # Info sur qui vient de parler
        if last_speaker and last_speaker != user_name:
            parts.append(f"NOTE: {last_speaker} vient de parler, pas {user_name}")
        
        # Messages en attente (seulement en privé)
        if is_private and pending_messages:
            msgs = "\n".join([f"- {s}: {m}" for s, m in pending_messages])
            parts.append(f"MESSAGES REÇUS:\n{msgs}")
        
        return "\n\n".join(parts)

personality = PersonalityCore()
